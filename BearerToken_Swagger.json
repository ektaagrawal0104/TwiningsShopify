{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "Shopify OAuth Token API",
    "description": "This API is used to obtain an OAuth token from Shopify."
  },
  "host": "tu-i-b2b-dev.myshopify.com",
  "basePath": "/admin/oauth",
  "schemes": [
    "https"
  ],
  "consumes": [
    "application/x-www-form-urlencoded"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/access_token": {
      "post": {
        "summary": "Request OAuth Token",
        "description": "Obtain an OAuth access token using the client credentials flow. This requires a valid `client_id`, `client_secret`, `grant_type`, and `resource`.",
        "parameters": [
          {
            "name": "client_id",
            "in": "formData",
            "description": "",
            "required": true,
            "type": "string"
          },
          {
            "name": "client_secret",
            "in": "formData",
            "description": "",
            "required": true,
            "type": "string"
          },
          {
            "name": "grant_type",
            "in": "formData",
            "description": "",
            "required": true,
            "type": "string",
            "default": "client_credentials"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Token Response",
            "schema": {
              "type": "object",
              "properties": {
		"access_token": {
                  "type": "string",
                  "example": "eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiIs..."
                },
		"scope": {
                  "type": "string",
                  "example": "https://usnconeboxax1aos.cloud.onebox.dynamics.com"
                },                
                "expires_in": {
                  "type": "string",
                  "example": "3599"
                }                               
              }
            }
          },
          "400": {
            "description": "Invalid request or credentials",
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "invalid_client"
                },
                "error_description": {
                  "type": "string",
                  "example": "AADSTS7000215: Invalid client secret is provided."
                }
              }
            }
          }
        }
      }
    }
  }
}