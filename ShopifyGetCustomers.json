{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "Shopify Customers API",
    "description": "Retrieve Shopify customers"
  },
  "host": "tu-i-b2b-dev.myshopify.com",
  "basePath": "/admin/api/2026-04",
  "schemes": [
    "https"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/customers.json": {
      "get": {
        "operationId": "GetCustomers",
        "summary": "Get Customers",
        "description": "Returns a list of customers",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 50
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "schema": {
              "$ref": "#/definitions/CustomersResponse"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "CustomersResponse": {
      "type": "object",
      "properties": {
        "customers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Customer"
          }
        }
      }
    },
    "Customer": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "format": "int64"
        },
        "first_name": {
          "type": "string"
        },
        "last_name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "orders_count": {
          "type": "integer"
        },
        "total_spent": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        }
      }
    }
  }
}