{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "Shopify Customers API",
    "description": "Retrieve Shopify customers"
  },
  "host": "tu-i-b2b-dev.myshopify.com",
  "basePath": "/admin/api/2026-04",
  "schemes": [
    "https"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/customers.json": {
      "get": {
        "operationId": "GetCustomers",
        "summary": "Get Customers",
        "description": "Returns a list of Shopify customers",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 50
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "schema": {
              "$ref": "#/definitions/CustomersResponse"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "CustomersResponse": {
      "type": "object",
      "properties": {
        "customers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Customer"
          }
        }
      }
    },

    "Customer": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "format": "int64"
        },
        "created_at": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        },
        "first_name": {
          "type": "string"
        },
        "last_name": {
          "type": "string"
        },
        "orders_count": {
          "type": "integer"
        },
        "state": {
          "type": "string"
        },
        "total_spent": {
          "type": "string"
        },
        "last_order_id": {
          "type": "integer",
          "format": "int64"
        },
        "note": {
          "type": "string"
        },
        "verified_email": {
          "type": "boolean"
        },
        "multipass_identifier": {
          "type": "string"
        },
        "tax_exempt": {
          "type": "boolean"
        },
        "tags": {
          "type": "string"
        },
        "last_order_name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "currency": {
          "type": "string"
        },
        "addresses": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Address"
          }
        },
        "tax_exemptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "email_marketing_consent": {
          "$ref": "#/definitions/EmailMarketingConsent"
        },
        "sms_marketing_consent": {
          "$ref": "#/definitions/SmsMarketingConsent"
        },
        "admin_graphql_api_id": {
          "type": "string"
        },
        "default_address": {
          "$ref": "#/definitions/Address"
        }
      }
    },

    "Address": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "format": "int64"
        },
        "customer_id": {
          "type": "integer",
          "format": "int64"
        },
        "first_name": {
          "type": "string"
        },
        "last_name": {
          "type": "string"
        },
        "company": {
          "type": "string"
        },
        "address1": {
          "type": "string"
        },
        "address2": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "province": {
          "type": "string"
        },
        "country": {
          "type": "string"
        },
        "zip": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "province_code": {
          "type": "string"
        },
        "country_code": {
          "type": "string"
        },
        "country_name": {
          "type": "string"
        },
        "default": {
          "type": "boolean"
        }
      }
    },

    "EmailMarketingConsent": {
      "type": "object",
      "properties": {
        "state": {
          "type": "string"
        },
        "opt_in_level": {
          "type": "string"
        },
        "consent_updated_at": {
          "type": "string"
        }
      }
    },

    "SmsMarketingConsent": {
      "type": "object",
      "properties": {
        "state": {
          "type": "string"
        },
        "opt_in_level": {
          "type": "string"
        },
        "consent_updated_at": {
          "type": "string"
        },
        "consent_collected_from": {
          "type": "string"
        }
      }
    }
  }
}