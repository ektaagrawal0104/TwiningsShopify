{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "Shopify OAuth Token API"
  },
  "host": "tu-i-b2b-dev.myshopify.com",
  "basePath": "/admin/oauth",
  "schemes": [
    "https"
  ],
  "consumes": [
    "application/x-www-form-urlencoded"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/access_token": {
      "post": {
        "operationId": "GetAccessToken",
        "parameters": [
          {
            "name": "client_id",
            "in": "formData",
            "required": true,
            "type": "string"
          },
          {
            "name": "client_secret",
            "in": "formData",
            "required": true,
            "type": "string"
          },
          {
            "name": "grant_type",
            "in": "formData",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Token Response",
            "schema": {
              "$ref": "#/definitions/TokenResponse"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "TokenResponse": {
      "type": "object",
      "properties": {
        "access_token": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "expires_in": {
          "type": "integer",
          "format": "int32"
        }
      }
    }
  }
}